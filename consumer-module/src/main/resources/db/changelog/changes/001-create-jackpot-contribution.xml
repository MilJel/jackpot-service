<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001" author="jackpot-dev">
        <comment>Kreiranje tabele jackpot_contribution</comment>

        <createTable tableName="jackpot_contribution">
            <column name="bet_id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="jackpot_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="stake_amount" type="DECIMAL(19, 4)">
                <constraints nullable="false"/>
            </column>
            <column name="contribution_amount" type="DECIMAL(19, 4)">
                <constraints nullable="false"/>
            </column>
            <column name="current_jackpot_amount" type="DECIMAL(19, 4)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at_date" type="DATE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_jackpot_contribution_jackpot_id"
                     tableName="jackpot_contribution">
            <column name="jackpot_id"/>
        </createIndex>

        <createIndex indexName="idx_jackpot_contribution_user_id"
                     tableName="jackpot_contribution">
            <column name="user_id"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>
